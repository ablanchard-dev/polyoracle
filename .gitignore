# .env included on user request (private repo, no real secrets — only URLs + paper config)

# Phase E2 (2026-05-11) — .env.live contains PRIVATE_KEY for live trading.
# NEVER track. Lives ONLY on the VPS via systemd Environment= or chmod 600 file.
.env.live
backend/.env.live

# Phase F live setup (2026-05-17) — backend/.env now carries live wallet secrets
# (POLYMARKET_PRIVATE_KEY, CLOB L2 creds, RELAYER key). Never track.
backend/.env
backend/.env.bak*
.env.production
# CLOB L2 credentials cache (apiKey/secret/passphrase derived from PRIVATE_KEY)
data/_polymarket_l2_creds.json
# Smoke + private logs (could contain wallet info if debug enabled)
backend/_smoke_strict_logs/

# Phase G DB-pull disaster fix (2026-05-18) — runtime DB MUST NOT be in git.
# Previous LFS exception !data/polyoracle.db caused 2.4GB live DB to be replaced
# by 134-byte version during pull → sqlite malformed → bot down.
# Lives only on VPS, hourly backups also excluded.
*.db
*.sqlite
*.db-wal
*.db-shm
data/_hourly_backups/
data/_reclass_backups/
data/_backups_audit/
data/_backups_pre_p0/
data/_backups_pre_watchlist/
data/_recovery_*/
data/wallet_polling_state.json
data/logs/audit.log

# Runtime logs (rotated, regenerable)
backend.dev.log
backend.dev.err.log
_auto_check_loop.log
_run_v0_5_10_dense_scan.log

